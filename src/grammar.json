{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "varlink",
  "rules": {
    "interface": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "declaration",
          "content": {
            "type": "SYMBOL",
            "name": "interface_declaration"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_eventually_eol"
              },
              {
                "type": "SYMBOL",
                "name": "declaration"
              }
            ]
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        }
      ]
    },
    "_": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_hspace"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        }
      ]
    },
    "_eventually_eol": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_hspace"
              },
              {
                "type": "SYMBOL",
                "name": "comment"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_eol"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        }
      ]
    },
    "_hspace": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "comment": {
      "type": "PATTERN",
      "value": "#[^\\n]*"
    },
    "_eol": {
      "type": "PATTERN",
      "value": "\\n"
    },
    "declaration": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "typedef"
        },
        {
          "type": "SYMBOL",
          "name": "error"
        },
        {
          "type": "SYMBOL",
          "name": "method"
        }
      ]
    },
    "keyword_interface": {
      "type": "STRING",
      "value": "interface"
    },
    "interface_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "SYMBOL",
            "name": "keyword_interface"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "interface_name"
          }
        }
      ]
    },
    "keyword_type": {
      "type": "STRING",
      "value": "type"
    },
    "typedef": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "SYMBOL",
            "name": "keyword_type"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "typedef_name"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "struct"
              },
              {
                "type": "SYMBOL",
                "name": "enum"
              }
            ]
          }
        }
      ]
    },
    "keyword_error": {
      "type": "STRING",
      "value": "error"
    },
    "error": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "SYMBOL",
            "name": "keyword_error"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "error_name"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "struct"
          }
        }
      ]
    },
    "keyword_method": {
      "type": "STRING",
      "value": "method"
    },
    "arrow": {
      "type": "STRING",
      "value": "->"
    },
    "method": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "SYMBOL",
            "name": "keyword_method"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "method_name"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "input",
          "content": {
            "type": "SYMBOL",
            "name": "struct"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "arrow",
          "content": {
            "type": "SYMBOL",
            "name": "arrow"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "output",
          "content": {
            "type": "SYMBOL",
            "name": "struct"
          }
        }
      ]
    },
    "struct": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "FIELD",
                  "name": "member",
                  "content": {
                    "type": "SYMBOL",
                    "name": "struct_field"
                  }
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SYMBOL",
                    "name": "_"
                  }
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "REPEAT",
                        "content": {
                          "type": "SYMBOL",
                          "name": "_"
                        }
                      },
                      {
                        "type": "FIELD",
                        "name": "member",
                        "content": {
                          "type": "SYMBOL",
                          "name": "struct_field"
                        }
                      },
                      {
                        "type": "REPEAT",
                        "content": {
                          "type": "SYMBOL",
                          "name": "_"
                        }
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "struct_field": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "struct_field_name"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "type"
          }
        }
      ]
    },
    "enum": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_"
          }
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "member",
              "content": {
                "type": "SYMBOL",
                "name": "enum_member_name"
              }
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SYMBOL",
                "name": "_"
              }
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": ","
                  },
                  {
                    "type": "REPEAT",
                    "content": {
                      "type": "SYMBOL",
                      "name": "_"
                    }
                  },
                  {
                    "type": "FIELD",
                    "name": "member",
                    "content": {
                      "type": "SYMBOL",
                      "name": "enum_member_name"
                    }
                  },
                  {
                    "type": "REPEAT",
                    "content": {
                      "type": "SYMBOL",
                      "name": "_"
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "type": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "maybe"
        },
        {
          "type": "SYMBOL",
          "name": "_just"
        }
      ]
    },
    "questionmark": {
      "type": "STRING",
      "value": "?"
    },
    "maybe": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "questionmark",
          "content": {
            "type": "SYMBOL",
            "name": "questionmark"
          }
        },
        {
          "type": "FIELD",
          "name": "just",
          "content": {
            "type": "SYMBOL",
            "name": "type"
          }
        }
      ]
    },
    "_just": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "struct"
        },
        {
          "type": "SYMBOL",
          "name": "enum"
        },
        {
          "type": "SYMBOL",
          "name": "array"
        },
        {
          "type": "SYMBOL",
          "name": "dict"
        },
        {
          "type": "SYMBOL",
          "name": "bool"
        },
        {
          "type": "SYMBOL",
          "name": "int"
        },
        {
          "type": "SYMBOL",
          "name": "float"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "object"
        },
        {
          "type": "SYMBOL",
          "name": "any"
        },
        {
          "type": "SYMBOL",
          "name": "typeref"
        }
      ]
    },
    "array": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "STRING",
          "value": "]"
        },
        {
          "type": "FIELD",
          "name": "type",
          "content": {
            "type": "SYMBOL",
            "name": "type"
          }
        }
      ]
    },
    "dict": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "STRING",
          "value": "]"
        },
        {
          "type": "FIELD",
          "name": "type",
          "content": {
            "type": "SYMBOL",
            "name": "type"
          }
        }
      ]
    },
    "bool": {
      "type": "STRING",
      "value": "bool"
    },
    "int": {
      "type": "STRING",
      "value": "int"
    },
    "float": {
      "type": "STRING",
      "value": "float"
    },
    "string": {
      "type": "STRING",
