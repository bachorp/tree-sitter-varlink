    "typedef_name": {
      "type": "SYMBOL",
      "name": "name"
    },
    "error_name": {
      "type": "SYMBOL",
      "name": "name"
    },
    "method_name": {
      "type": "SYMBOL",
      "name": "name"
    },
    "typeref": {
      "type": "SYMBOL",
      "name": "name"
    },
    "struct_field_name": {
      "type": "SYMBOL",
      "name": "_field_name"
    },
    "enum_member_name": {
      "type": "SYMBOL",
      "name": "_field_name"
    },
    "name": {
      "type": "PATTERN",
      "value": "[A-Z][a-zA-Z0-9]*"
    },
    "_field_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z](_?[a-zA-Z0-9])*"
    },
    "interface_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z](-*[a-zA-Z0-9])*(\\.[a-zA-Z0-9](-*[a-zA-Z0-9])*)+"
    }
  },
  "extras": [],
